#!/usr/bin/env python3
"""Web interface for Pirate Radio — station selection and volume control."""

import json
import os
import re
import socket
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse

VLC_HOST = "127.0.0.1"
VLC_PORT = 9294
PLAYLIST_PATH = "/home/pi/.config/vlc/playlist.m3u"
WWW_DIR = "/home/pi/pirate-radio/www"
HTTP_PORT = 80


def vlc_cmd(cmd):
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(4)
    try:
        s.connect((VLC_HOST, VLC_PORT))
        buf = b""
        while b"> " not in buf:
            buf += s.recv(512)
        s.send((cmd + "\n").encode())
        buf = b""
        while True:
            try:
                chunk = s.recv(4096)
                if not chunk:
                    break
                buf += chunk
                if b"\n> " in buf or buf.endswith(b"> "):
                    break
            except socket.timeout:
                break
        return buf.decode("utf-8", errors="replace")
    except Exception:
        return ""
    finally:
        s.close()


def get_status():
    raw = vlc_cmd("status")
    vol_m   = re.search(r"audio volume: (\d+)", raw)
    state_m = re.search(r"state (\w+)", raw)
    url_m   = re.search(r"input: (.+?)\s*\)", raw)
    return {
        "volume":      int(vol_m.group(1)) if vol_m else 0,
        "state":       state_m.group(1) if state_m else "unknown",
        "current_url": url_m.group(1).strip() if url_m else "",
    }


def vlc_item_ids():
    """Return VLC's internal playlist IDs in order, skipping root nodes."""
    raw = vlc_cmd("playlist")
    ids = []
    for m in re.finditer(r'\|\s+\*?(\d+)\s+-\s+(.+)', raw):
        name = m.group(2).strip()
        if name not in ("Playlist", "Media Library"):
            ids.append(int(m.group(1)))
    return ids


def read_playlist():
    stations = []
    try:
        with open(PLAYLIST_PATH) as f:
            name = None
            for line in f:
                line = line.strip()
                if line.startswith("#EXTINF:"):
                    name = line.split(",", 1)[1] if "," in line else ""
                elif line and not line.startswith("#"):
                    stations.append({"name": name or line, "url": line})
                    name = None
    except Exception:
        pass
    return stations


class Handler(BaseHTTPRequestHandler):
    def log_message(self, *args):
        pass

    def send_json(self, data, status=200):
        body = json.dumps(data).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", len(body))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        path = urlparse(self.path).path
        if path == "/":
            path = "/index.html"

        if path == "/api/status":
            self.send_json(get_status())
        elif path == "/api/stations":
            self.send_json(read_playlist())
        else:
            file_path = os.path.join(WWW_DIR, path.lstrip("/"))
            if os.path.isfile(file_path):
                with open(file_path, "rb") as f:
                    body = f.read()
                ext = os.path.splitext(file_path)[1]
                types = {".html": "text/html; charset=utf-8", ".css": "text/css", ".js": "application/javascript"}
                self.send_response(200)
                self.send_header("Content-Type", types.get(ext, "application/octet-stream"))
                self.send_header("Content-Length", len(body))
                self.end_headers()
                self.wfile.write(body)
            else:
                self.send_response(404)
                self.end_headers()

    def do_POST(self):
        if urlparse(self.path).path == "/api/command":
            length = int(self.headers.get("Content-Length", 0))
            body = json.loads(self.rfile.read(length))
            cmd = body.get("cmd", "")
            m = re.match(r"goto (\d+)$", cmd)
            if m:
                idx = int(m.group(1))  # 1-based index from the UI
                ids = vlc_item_ids()
                if 1 <= idx <= len(ids):
                    cmd = f"goto {ids[idx - 1]}"
            vlc_cmd(cmd)
            self.send_json({"ok": True})
        else:
            self.send_response(404)
            self.end_headers()


if __name__ == "__main__":
    HTTPServer(("0.0.0.0", HTTP_PORT), Handler).serve_forever()
